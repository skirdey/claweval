{
  "agents": [
    {
      "name": "openclaw",
      "service": "openclaw",
      "port": 5001,
      "enabled": true,
      "description": "OpenClaw CLI agent (Node.js)"
    },
    {
      "name": "ironclaw",
      "service": "ironclaw",
      "port": 5002,
      "enabled": true,
      "description": "IronClaw Rust agent (nearai/ironclaw)"
    },
    {
      "name": "nanobot",
      "service": "nanobot",
      "port": 5003,
      "enabled": true,
      "description": "Nanobot Python agent"
    },
    {
      "name": "picoclaw",
      "service": "picoclaw",
      "port": 5004,
      "enabled": true,
      "description": "PicoClaw Go agent"
    },
    {
      "name": "openai_direct",
      "service": "openai-direct",
      "port": 5005,
      "enabled": true,
      "description": "Raw LLM baseline via OpenRouter (no agent framework)"
    },
    {
      "name": "hermes",
      "service": "hermes",
      "port": 5006,
      "enabled": true,
      "description": "Hermes Agent (Nous Research) - self-improving AI agent"
    }
  ],
  "suites": [
    "matrix_basic.json",
    "matrix_memory.json",
    "matrix_reasoning.json",
    "matrix_structured.json",
    "matrix_async_simulated.json",
    "matrix_tools_grounding.json",
    "matrix_longhorizon_reliability.json",
    "matrix_openclaw_scheduler.json",
    "matrix_openclaw_browser.json",
    "matrix_openclaw_webfetch.json",
    "matrix_openclaw_skills.json",
    "matrix_browser_install.json"
  ],
  "suite_metadata": {
    "matrix_basic": {
      "capability_tags": ["core"],
      "scoring_class": "core"
    },
    "matrix_memory": {
      "capability_tags": ["core", "memory"],
      "scoring_class": "core"
    },
    "matrix_reasoning": {
      "capability_tags": ["core", "reasoning"],
      "scoring_class": "core"
    },
    "matrix_structured": {
      "capability_tags": ["core", "structured"],
      "scoring_class": "core"
    },
    "matrix_async_simulated": {
      "capability_tags": ["core", "async", "oracles"],
      "scoring_class": "core"
    },
    "matrix_tools_grounding": {
      "capability_tags": ["core", "tools", "oracles"],
      "scoring_class": "core"
    },
    "matrix_longhorizon_reliability": {
      "capability_tags": ["core", "memory", "stress"],
      "scoring_class": "core"
    },
    "matrix_openclaw_scheduler": {
      "capability_tags": ["advanced", "scheduler", "oracles"],
      "scoring_class": "advanced"
    },
    "matrix_openclaw_browser": {
      "capability_tags": ["advanced", "browser", "oracles"],
      "scoring_class": "advanced"
    },
    "matrix_openclaw_webfetch": {
      "capability_tags": ["advanced", "webfetch", "oracles"],
      "scoring_class": "advanced"
    },
    "matrix_openclaw_skills": {
      "capability_tags": ["advanced", "skills", "oracles"],
      "scoring_class": "advanced"
    },
    "matrix_browser_install": {
      "capability_tags": ["advanced", "browser", "install", "tool_use"],
      "scoring_class": "advanced"
    }
  },
  "judge_backend": {
    "type": "openai",
    "base_url": "https://openrouter.ai/api/v1",
    "model": "qwen/qwen3.5-397b-a17b",
    "api_key": "${OPENROUTER_API_KEY}"
  },
  "options": {
    "health_check_timeout_seconds": 60,
    "default_jobs": 1,
    "global_sidecars": ["oracle-sink"]
  }
}
