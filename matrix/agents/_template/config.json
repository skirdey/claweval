{
  "_comment": "Copy this template to create a new agent. See README.md for details.",
  "agent_name": "my_agent",
  "mode": "cli",

  "_mode_options": "cli | openai_proxy | http_proxy",

  "_cli_fields": {
    "command": "my-agent-binary",
    "args": ["chat", "--message", "{message}", "--session", "{session_id}"],
    "response_field": null,
    "timeout_seconds": 120,
    "env": {}
  },

  "_openai_proxy_fields": {
    "base_url": "https://openrouter.ai/api/v1",
    "model": "anthropic/claude-opus-4-6",
    "system_prompt": "You are a helpful assistant.",
    "temperature": 0.7,
    "max_tokens": 1024
  },

  "_http_proxy_fields": {
    "target_url": "http://localhost:4000/chat",
    "session_field": "session_id",
    "message_field": "message",
    "response_field": "response"
  },

  "command": "my-agent-binary",
  "args": ["chat", "--message", "{message}"],
  "timeout_seconds": 120
}
