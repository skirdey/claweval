{
  "name": "matrix_openclaw_skills",
  "description": "OpenClaw skill invocation and error recovery checks.",
  "backend": {
    "type": "http",
    "url": "http://localhost:5000/chat"
  },
  "global_repeats": 1,
  "scoring_class": "advanced",
  "capability_tags": ["advanced", "skills", "oracles"],
  "episodes": [
    {
      "id": "skill_dispatch_marker",
      "description": "Agent should use a tool/skill path and emit oracle marker.",
      "steps": [
        {"type": "http_probe", "method": "DELETE", "url": "http://localhost:5010/events?run_id=skills_suite"},
        {
          "type": "user",
          "input": "Use your skills/tools to POST to http://oracle-sink:5010/events with run_id skills_suite, session_id sk_1, event_type skill_dispatch, payload {\"skill\":\"fetcher\",\"marker\":\"SKILL-DISPATCH-1\"}. Reply OK once done."
        },
        {
          "type": "poll",
          "interval_ms": 1000,
          "timeout_ms": 15000,
          "probe": {
            "type": "http_probe",
            "method": "GET",
            "url": "http://localhost:5010/events?run_id=skills_suite&session_id=sk_1&event_type=skill_dispatch"
          },
          "until": {"type": "contains_text", "text": "SKILL-DISPATCH-1"}
        }
      ],
      "checks": [
        {"type": "contains", "step": 1, "text": "OK", "case_sensitive": false},
        {"type": "eventually_contains", "step": 2, "text": "SKILL-DISPATCH-1", "within_ms": 15000}
      ]
    },
    {
      "id": "skill_argument_contract_json",
      "description": "Return strict schema-conformant output for a structured skill request.",
      "steps": [
        {
          "type": "user",
          "input": "Return only JSON with this exact shape: {\"skill\":\"formatter\",\"ok\":true,\"items\":[{\"name\":\"alpha\",\"score\":1}]}."
        }
      ],
      "checks": [
        {
          "type": "json_schema",
          "step": 0,
          "schema": {
            "type": "object",
            "required": ["skill", "ok", "items"],
            "properties": {
              "skill": {"type": "string"},
              "ok": {"type": "boolean"},
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "score"],
                  "properties": {
                    "name": {"type": "string"},
                    "score": {"type": "number"}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        {"type": "json_pointer_equals", "step": 0, "pointer": "/skill", "expected": "formatter"},
        {"type": "json_pointer_equals", "step": 0, "pointer": "/ok", "expected": true}
      ]
    },
    {
      "id": "skill_error_recovery",
      "description": "Recover from invalid first request and provide corrected second result.",
      "steps": [
        {
          "type": "user",
          "input": "First intentionally reply with ERROR_ONLY. Next message I send will contain corrected input."
        },
        {
          "type": "user",
          "input": "Now corrected input: output exactly RECOVERED-OK."
        }
      ],
      "checks": [
        {"type": "contains", "step": 0, "text": "ERROR", "case_sensitive": false},
        {"type": "equals_trim", "step": 1, "text": "RECOVERED-OK", "case_sensitive": true}
      ]
    }
  ]
}
