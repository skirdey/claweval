{
  "name": "matrix_openclaw_scheduler",
  "description": "OpenClaw-advanced scheduling and delayed task behavior with oracle checks.",
  "backend": {
    "type": "http",
    "url": "http://localhost:5000/chat"
  },
  "global_repeats": 1,
  "scoring_class": "advanced",
  "capability_tags": ["advanced", "scheduler", "oracles"],
  "episodes": [
    {
      "id": "schedule_emit_event_60s",
      "description": "Ask agent to schedule a delayed webhook write and verify appearance.",
      "steps": [
        {"type": "http_probe", "method": "DELETE", "url": "http://localhost:5010/events?run_id=scheduler_suite"},
        {
          "type": "user",
          "input": "Schedule a task roughly 60 seconds from now that POSTs to http://oracle-sink:5010/events with JSON {\"run_id\":\"scheduler_suite\",\"session_id\":\"sched_1\",\"event_type\":\"heartbeat_fired\",\"payload\":{\"marker\":\"SCHED-60\"}}. Reply only with SCHEDULED."
        },
        {
          "type": "poll",
          "interval_ms": 5000,
          "timeout_ms": 90000,
          "probe": {
            "type": "http_probe",
            "url": "http://localhost:5010/events?run_id=scheduler_suite&session_id=sched_1&event_type=heartbeat_fired",
            "method": "GET"
          },
          "until": {"type": "contains_text", "text": "SCHED-60"}
        }
      ],
      "checks": [
        {"type": "contains", "step": 1, "text": "SCHEDULED", "case_sensitive": false},
        {"type": "eventually_contains", "step": 2, "text": "SCHED-60", "within_ms": 90000},
        {"type": "within_time_window_ms", "step": 2, "min_ms": 55000, "max_ms": 90000}
      ]
    },
    {
      "id": "schedule_cancel_prevents_emit",
      "description": "Schedule then cancel; ensure marker never appears.",
      "steps": [
        {"type": "http_probe", "method": "DELETE", "url": "http://localhost:5010/events?run_id=scheduler_suite_cancel"},
        {
          "type": "user",
          "input": "Schedule a task for 45 seconds from now that posts marker CANCEL-ME to oracle sink. Then immediately cancel it. Reply only CANCELLED."
        },
        {"type": "sleep", "ms": 55000},
        {
          "type": "http_probe",
          "method": "GET",
          "url": "http://localhost:5010/events?run_id=scheduler_suite_cancel"
        }
      ],
      "checks": [
        {"type": "contains", "step": 1, "text": "CANCELLED", "case_sensitive": false},
        {"type": "not_contains", "step": 3, "text": "CANCEL-ME", "case_sensitive": true}
      ]
    },
    {
      "id": "scheduled_payload_context_integrity",
      "description": "Delayed event must include prior context token unchanged.",
      "steps": [
        {"type": "http_probe", "method": "DELETE", "url": "http://localhost:5010/events?run_id=scheduler_ctx"},
        {
          "type": "user",
          "input": "Remember token OMEGA-CTX-44. In about 60 seconds post to oracle sink with run_id scheduler_ctx and payload {\"token\":\"OMEGA-CTX-44\"}. Reply ACK."
        },
        {
          "type": "poll",
          "interval_ms": 4000,
          "timeout_ms": 90000,
          "probe": {
            "type": "http_probe",
            "url": "http://localhost:5010/events?run_id=scheduler_ctx",
            "method": "GET"
          },
          "until": {"type": "contains_text", "text": "OMEGA-CTX-44"}
        }
      ],
      "checks": [
        {"type": "contains", "step": 1, "text": "ACK", "case_sensitive": false},
        {"type": "eventually_contains", "step": 2, "text": "OMEGA-CTX-44", "within_ms": 90000}
      ]
    }
  ]
}
