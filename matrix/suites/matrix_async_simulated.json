{
  "name": "matrix_async_simulated",
  "description": "Simulated async flows with oracle-backed polling and timing checks.",
  "backend": {
    "type": "http",
    "url": "http://localhost:5000/chat"
  },
  "global_repeats": 1,
  "episodes": [
    {
      "id": "oracle_event_written",
      "description": "Agent emits a specific event to oracle sink; runner polls for visibility.",
      "steps": [
        {
          "type": "http_probe",
          "name": "clear_events",
          "method": "DELETE",
          "url": "http://localhost:5010/events"
        },
        {
          "type": "user",
          "name": "emit_event",
          "input": "Use any available tool to POST JSON to http://oracle-sink:5010/events with run_id=async_suite, session_id=sim_1, event_type=task_complete, payload={\"marker\":\"ASYNC-ONE\"}. Then reply with exactly DONE."
        },
        {
          "type": "poll",
          "name": "poll_oracle",
          "interval_ms": 1000,
          "timeout_ms": 15000,
          "probe": {
            "type": "http_probe",
            "url": "http://localhost:5010/events?run_id=async_suite&session_id=sim_1&event_type=task_complete",
            "method": "GET"
          },
          "until": {
            "type": "contains_text",
            "text": "ASYNC-ONE"
          }
        }
      ],
      "checks": [
        {"type": "contains", "step": 1, "text": "DONE", "case_sensitive": false},
        {"type": "eventually_contains", "step": 2, "text": "ASYNC-ONE", "within_ms": 15000},
        {"type": "status_code_equals", "step": 2, "code": 200}
      ]
    },
    {
      "id": "poll_dynamic_readiness",
      "description": "Runner waits on dynamic readiness endpoint and validates timing window.",
      "steps": [
        {
          "type": "poll",
          "name": "wait_ready",
          "interval_ms": 1000,
          "timeout_ms": 12000,
          "probe": {
            "type": "http_probe",
            "url": "http://localhost:5010/fixtures/dynamic",
            "method": "GET"
          },
          "until": {
            "type": "json_pointer_equals",
            "pointer": "/ready",
            "expected": true
          }
        }
      ],
      "checks": [
        {"type": "json_pointer_equals", "step": 0, "pointer": "/ready", "expected": true},
        {"type": "json_pointer_exists", "step": 0, "pointer": "/token"},
        {"type": "within_time_window_ms", "step": 0, "min_ms": 0, "max_ms": 12000}
      ]
    },
    {
      "id": "exec_probe_sanity",
      "description": "Exec step smoke test with output and exit diagnostics.",
      "steps": [
        {
          "type": "exec",
          "name": "run_echo",
          "command": "python",
          "args": ["-c", "print('EXEC_OK_77')"]
        }
      ],
      "checks": [
        {"type": "contains", "step": 0, "text": "EXEC_OK_77", "case_sensitive": true}
      ]
    }
  ]
}
